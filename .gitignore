# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# sql.js WASM binary — embedded into main.js at build time (esbuild binary
# loader), not needed as a standalone file in the plugin/repo root.
/sql-wasm.wasm

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Decrypted jwpub analysis output (contains copyrighted content)
scripts/out/

# User-supplied Bible jwpub file for the Bible-verse popup feature — copyrighted
# content, never committed. Written here at runtime by main.ts.setBibleFile().
/bible-cache.jwpub
